# ============================================================
# Variables de entorno para docker-compose.yml
# Copia a .env y ajusta si es necesario.
# Los valores por defecto funcionan para desarrollo local.
# ============================================================

# ── Permisos de los contenedores ────────────────────────────
# Los servicios corren con este UID/GID (NO root) y escriben
# en los volúmenes bindeados en ./data/.
#
# Forma recomendada de inicializar:
#   ./scripts/bootstrap.sh    (crea carpetas + genera .env con tu UID)
#   docker compose up -d
#
# Si editas este .env a mano, pon aquí el resultado de `id -u` / `id -g`.
HOST_UID=1000
HOST_GID=1000

# ── ChromaDB ────────────────────────────────────────────────
CHROMA_PORT=8001

# ── Neo4j ───────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpass
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

